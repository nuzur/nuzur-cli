#!/usr/bin/env bash
# nuzur deploy teardown for {{.Identifier}} (idempotent; safe to re-run). Removes
# everything the bootstrap installed EXCEPT the box itself and shared packages
# (docker/mysql/caddy stay installed). The database is dropped only with --purge.
# Deliberately no `set -e`: teardown is best-effort — a missing unit or already
# removed file must not stop the rest of the cleanup.
set -uo pipefail
export HOME=/root
export USER=root

echo "[nuzur-destroy] tearing down {{.Identifier}}"

# ── 1. Stop + remove the app and agent systemd services ──────────────────────
for unit in {{.Identifier}}-api.service nuzur-agent.service; do
  systemctl stop "$unit" 2>/dev/null || true
  systemctl disable "$unit" 2>/dev/null || true
  rm -f "/etc/systemd/system/$unit"
  systemctl reset-failed "$unit" 2>/dev/null || true
done
systemctl daemon-reload 2>/dev/null || true

# ── 2. Remove the app container + image ──────────────────────────────────────
docker rm -f {{.ContainerName}} 2>/dev/null || true
docker rmi -f {{.ImageName}} 2>/dev/null || true

# ── 3. Remove the Caddy front-door site (the whole Caddyfile is nuzur's) ──────
rm -f /etc/caddy/Caddyfile
systemctl reload caddy 2>/dev/null || systemctl restart caddy 2>/dev/null || true

# ── 4. Remove the backup cron, config, secrets and agent pairing creds ───────
rm -f /etc/cron.d/nuzur-backup
rm -rf /etc/nuzur
rm -rf /root/.config/nuzur

{{if .Purge}}
# ── 5. Purge the database + app user (opt-in; irreversible) ───────────────────
mysql <<SQL 2>/dev/null || true
DROP DATABASE IF EXISTS \`{{.DBName}}\`;
DROP USER IF EXISTS '{{.DBUser}}'@'localhost';
FLUSH PRIVILEGES;
SQL
echo "[nuzur-destroy] purged database {{.DBName}}"
{{end}}

echo "[nuzur-destroy] teardown complete for {{.Identifier}}"
